{
  "name": "rung_250_ops_indie_launch_uncertainty_routing",
  "ontology_name": "rung_250_ops_indie_launch_uncertainty_routing",
  "utterances": [
    "global_launch is a milestone.",
    "streamer_preview_keys depends on store_page_lock.",
    "embargo_briefing depends on streamer_preview_keys.",
    "store_page_lock has supplier platform_ops_vendor.",
    "platform_ops_vendor is on_time.",
    {
      "utterance": "Producer note: I think launch date might be June 3, but it is not locked yet.",
      "clarification_answers": [
        "Treat that as tentative only. Do not commit a hard launch date fact."
      ],
      "max_clarification_rounds": 2
    },
    "Update: platform_ops_vendor is delayed.",
    "Given this delay, what gets blocked first?"
  ],
  "validations": [
    {
      "id": "global_launch_milestone",
      "query": "milestone(global_launch).",
      "expect_status": "success",
      "min_rows": 1
    },
    {
      "id": "preview_depends_store_lock",
      "query": "depends_on(streamer_preview_keys, store_page_lock).",
      "expect_status": "success",
      "min_rows": 1
    },
    {
      "id": "embargo_depends_preview",
      "query": "depends_on(embargo_briefing, streamer_preview_keys).",
      "expect_status": "success",
      "min_rows": 1
    },
    {
      "id": "platform_vendor_delayed",
      "query": "supplier_status(platform_ops_vendor, delayed).",
      "expect_status": "success",
      "min_rows": 1
    }
  ]
}
