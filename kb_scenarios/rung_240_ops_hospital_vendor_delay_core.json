{
  "name": "rung_240_ops_hospital_vendor_delay_core",
  "ontology_name": "rung_240_ops_hospital_vendor_delay_core",
  "utterances": [
    "Site prep is a task.",
    "Foundation depends on site_prep.",
    "Interior buildout depends on foundation.",
    "Medical gas certification depends on interior_buildout.",
    "Go live depends on medical_gas_cert.",
    "medical_gas_cert has supplier medgas_vendor.",
    "medgas_vendor is on_time.",
    {
      "utterance": "Ops update: med gas vendor might be delayed now.",
      "clarification_answers": [
        "Use medgas_vendor and mark supplier_status as delayed."
      ],
      "max_clarification_rounds": 2
    },
    "go_live is a milestone.",
    "What is delayed right now?"
  ],
  "validations": [
    {
      "id": "foundation_depends_site_prep",
      "query": "depends_on(foundation, site_prep).",
      "expect_status": "success",
      "min_rows": 1
    },
    {
      "id": "interior_buildout_depends_foundation",
      "query": "depends_on(interior_buildout, foundation).",
      "expect_status": "success",
      "min_rows": 1
    },
    {
      "id": "medgas_supplier_link",
      "query": "task_supplier(medical_gas_cert, medgas_vendor).",
      "expect_status": "success",
      "min_rows": 1
    },
    {
      "id": "medgas_marked_delayed",
      "query": "supplier_status(medgas_vendor, delayed).",
      "expect_status": "success",
      "min_rows": 1
    },
    {
      "id": "go_live_milestone",
      "query": "milestone(go_live).",
      "expect_status": "success",
      "min_rows": 1
    }
  ]
}
