{
  "name": "demo_01_meeting_commitment_extractor",
  "ontology_name": "demo_01_meeting_commitment_extractor",
  "utterances": [
    "deliver_draft_friday is a commitment.",
    "maya owns deliver_draft_friday.",
    "launch depends on legal_approval.",
    "legal_approval depends on revised_privacy_language.",
    "launch depends on qa_pass.",
    "sam objected_to deliver_draft_friday.",
    "Who owns deliver_draft_friday?",
    "What does launch depend on?"
  ],
  "validations": [
    {
      "id": "commitment_recorded",
      "query": "commitment(deliver_draft_friday).",
      "expect_status": "success",
      "min_rows": 1
    },
    {
      "id": "owner_recorded",
      "query": "owns(maya, deliver_draft_friday).",
      "expect_status": "success",
      "min_rows": 1
    },
    {
      "id": "launch_dep_legal",
      "query": "depends_on(launch, legal_approval).",
      "expect_status": "success",
      "min_rows": 1
    },
    {
      "id": "legal_dep_privacy",
      "query": "depends_on(legal_approval, revised_privacy_language).",
      "expect_status": "success",
      "min_rows": 1
    },
    {
      "id": "launch_dep_qa",
      "query": "depends_on(launch, qa_pass).",
      "expect_status": "success",
      "min_rows": 1
    }
  ]
}
